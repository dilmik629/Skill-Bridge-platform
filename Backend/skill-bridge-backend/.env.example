APP_NAME=SkillBridge
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

LOG_CHANNEL=stack
LOG_LEVEL=debug

# ─── Database ─────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=skill_bridge_db
DB_USERNAME=root
DB_PASSWORD=

# ─── Sanctum ──────────────────────────────
SANCTUM_STATEFUL_DOMAINS=localhost:5173,localhost:3000

# ─── CORS ─────────────────────────────────
FRONTEND_URL=http://localhost:5173

# ─── Mail (optional) ──────────────────────
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="noreply@skillbridge.com"
MAIL_FROM_NAME="SkillBridge"